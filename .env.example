###########################################
# Core project settings
###########################################
ENV=dev
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=europe-west2
DATA_LAKE_BUCKET=your-bucket-name

###########################################
# Optional: set when service account already exists
###########################################
EXISTING_PIPELINE_SA_EMAIL=

###########################################
# BigQuery datasets
###########################################
BQ_DATASET_RAW=raw
BQ_DATASET_STAGING=staging
BQ_DATASET_ANALYTICS=analytics
BQ_DATASET_STREAMING=streaming

###########################################
# GCP credentials (paste SA JSON or use $(cat path))
###########################################
GCP_SERVICE_ACCOUNT_JSON='{"type":"service_account","project_id":"..."}'

###########################################
# Source API credentials
###########################################
TICKETMASTER_API_KEY=replace_me
SETLISTFM_API_KEY=replace_me
MUSICBRAINZ_API_KEY=replace_me

###########################################
# Pipeline mode: prototype (fast, <5 min) or production (full, <1 hr)
###########################################
PIPELINE_MODE=prototype

###########################################
# dlt ingestion settings
###########################################
TRACKED_ARTISTS=Metallica,BTS,Ariana Grande
MUSICBRAINZ_USER_AGENT=application-name/0.1 (contact: your-email@example.com)
SETLISTFM_USER_AGENT=application-name/0.1
DLT_DESTINATION=bigquery
DLT_DATASET=raw
# Optional: must match dataset location (e.g. EU, US, europe-west2)
DLT_BIGQUERY_LOCATION=europe-west2
# Set to 1 for verbose dlt error tracebacks
DLT_DEBUG_TRACEBACK=0
MAX_TOURING_ARTISTS=120
TICKETMASTER_MAX_PAGES=5
TICKETMASTER_PAGE_SIZE=200
# Multi-country markets (used in production; prototype defaults to US)
TICKETMASTER_COUNTRY_CODES=US,CA,GB,DE,IT
TICKETMASTER_MIN_UPCOMING_EVENTS=3
SETLISTFM_MAX_PAGES=10
SETLISTFM_REQUEST_DELAY=1.0
SETLISTFM_MAX_RETRIES=5
SETLISTFM_DAILY_LIMIT=1400
HTTP_MAX_RETRIES=3
HTTP_RETRY_BACKOFF_SECONDS=1.5

###########################################
# Kafka streaming (optional add-on)
###########################################
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC=ticket_events
POLL_INTERVAL_SECONDS=300
CONSUMER_FLUSH_INTERVAL=10

###########################################
# Dashboard
###########################################
# local = read from streamlit/data/ parquets; bigquery = query BQ live
DASHBOARD_MODE=local

###########################################
# Spark (Dataproc Serverless)
###########################################
# Set to any value to run on Dataproc Serverless instead of local Spark
# DATAPROC_SERVERLESS=1
